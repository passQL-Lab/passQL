            "type": "boolean"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "pageNumber": {
            "type": "integer",
            "format": "int32"
          },
          "unpaged": {
            "type": "boolean"
          },
          "offset": {
            "type": "integer",
            "format": "int64"
          },
          "sort": {
            "$ref": "#/components/schemas/SortObject"
          }
        }
      },
      "QuestionSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "topicCode": {
            "type": "string"
          },
          "difficulty": {
            "type": "integer",
            "format": "int32"
          },
          "stemPreview": {
            "type": "string"
          },
          "executionMode": {
            "type": "string",
            "enum": ["EXECUTABLE", "CONCEPT_ONLY"]
          }
        }
      },
      "SortObject": {
        "type": "object",
        "properties": {
          "sorted": {
            "type": "boolean"
          },
          "unsorted": {
            "type": "boolean"
          },
          "empty": {
            "type": "boolean"
          }
        }
      },
      "ChoiceItem": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["SQL", "TEXT"]
          },
          "body": {
            "type": "string"
          },
          "sortOrder": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "QuestionDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "topicCode": {
            "type": "string"
          },
          "subtopicCode": {
            "type": "string"
          },
          "difficulty": {
            "type": "integer",
            "format": "int32"
          },
          "executionMode": {
            "type": "string",
            "enum": ["EXECUTABLE", "CONCEPT_ONLY"]
          },
          "stem": {
            "type": "string"
          },
          "schemaDisplay": {
            "type": "string"
          },
          "choices": {
            "type": "array",
