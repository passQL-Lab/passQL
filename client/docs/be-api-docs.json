      "ProgressSummary": {
        "type": "object",
        "properties": {
          "solved": {
            "type": "integer",
            "format": "int32"
          },
          "correctRate": {
            "type": "number",
            "format": "double"
          },
          "streakDays": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "HeatmapEntry": {
        "type": "object",
        "properties": {
          "topicCode": {
            "type": "string"
