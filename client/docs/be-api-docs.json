{
  "openapi": "3.1.0",
  "info": {
    "title": "passQL API",
    "description": "SQL 학습 플랫폼 passQL 백엔드 API 문서",
    "version": "v0.0.3"
  },
  "servers": [
    {
      "url": "http://api.passql.suhsaechan.kr",
      "description": "Generated server url"
    }
