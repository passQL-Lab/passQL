          "isCorrect": {
            "type": "boolean"
          },
          "correctKey": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          }
        }
      },
      "ExecuteResult": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "object"
              }
            }
          },
          "rowCount": {
            "type": "integer",
            "format": "int32"
          },
          "elapsedMs": {
            "type": "integer",
            "format": "int64"
          },
          "errorCode": {
            "type": "string"
          },
          "errorMessage": {
            "type": "string"
          }
        }
      },
      "AiResult": {
        "type": "object",
